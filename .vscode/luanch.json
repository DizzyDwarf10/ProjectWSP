{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Chrome (Vite)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "breakOnLoad": true,
      "sourceMaps": true
    },
    {
      "name": "Debug Vite Dev Server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "autoAttachChildProcesses": true
    }
  ],
  "compounds": [
    {
      "name": "Full Debug: Vite + Chrome",
      "configurations": [
        "Debug Vite Dev Server",
        "Launch Chrome (Vite)"
      ],
      "stopAll": true
    }
  ]
}